{
  "name": "diswhook",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "author": "gergogyulai",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "webhooks",
    "discord",
    "discord-webhooks",
    "typescript",
    "nodejs"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "repository": "gergogyulai/diswhook",
  "scripts": {
    "build": "tsc && dts-bundle-generator -o dist/index.d.ts src/index.ts",
    "lint": "npx prettier --write src"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "discord-api-types": "^0.38.48",
    "dts-bundle-generator": "^9.5.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
