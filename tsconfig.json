{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "allowSyntheticDefaultImports": true,
  },
  "include": [
    "src"
  ]
}